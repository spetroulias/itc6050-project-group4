# --- PostgreSQL Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=books_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- pgAdmin (visual database browser) ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here

# --- dlt connection string ---
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above
DESTINATION__POSTGRES__CREDENTIALS=postgresql://postgres:your_password_here@postgres:5432/books_db